---
import { TOP_RISKS } from '../../data/dashboard.js';
---
<div class="tab-pane" id="tab-riesgos">

  <div class="section-label">Distribución de riesgo</div>
  <div class="stat-grid g4">
    <div class="stat-card c-red">
      <div class="stat-label">Muy Alto (Inherente)</div>
      <div class="stat-val c-red" data-counter="4">0</div>
      <div class="stat-sub">Score 20-25 · acción inmediata</div>
    </div>
    <div class="stat-card c-amber">
      <div class="stat-label">Alto (Inherente)</div>
      <div class="stat-val c-amber" data-counter="13">0</div>
      <div class="stat-sub">Score 15-19</div>
    </div>
    <div class="stat-card c-green">
      <div class="stat-label">Muy Bajo (Residual)</div>
      <div class="stat-val c-green" data-counter="37">0</div>
      <div class="stat-sub">tras aplicar 11 controles</div>
    </div>
    <div class="stat-card c-blue">
      <div class="stat-label">Reducción promedio</div>
      <div class="stat-val c-blue" data-counter="74" data-suffix="%">0%</div>
      <div class="stat-sub">efectividad de controles</div>
    </div>
  </div>

  <div class="row c32">
    <div class="card">
      <div class="card-head">
        <h3>Mapa de Calor 5×5 — Riesgo Inherente</h3>
        <span>Probabilidad (P) × Impacto (I) · ISO/IEC 27005</span>
      </div>
      <div class="card-body">
        <div class="heatmap-wrap"><canvas id="heatmapCanvas" width="640" height="440"></canvas></div>
      </div>
    </div>
    <div class="card">
      <div class="card-head">
        <h3>Distribución — Antes vs Después</h3>
      </div>
      <div class="card-body">
        <div class="chart-wrap h360"><canvas id="chartRiskDist"></canvas></div>
      </div>
    </div>
  </div>

  <div class="section-label">Registro de riesgos críticos (Top 10 inherente)</div>
  <div class="card">
    <div class="card-body table-scroll" style="padding:0">
      <table>
        <thead><tr><th>ID</th><th>Activo</th><th>Vector</th><th>Score Inherente</th><th>Score Residual</th><th>Efectividad Control</th><th>MITRE</th></tr></thead>
        <tbody id="fullRisksTable">
          {TOP_RISKS.map(r => (
            <tr>
              <td><span class="badge b-blue">{r.id}</span></td>
              <td>{r.asset}</td>
              <td style="font-size:12px">{r.threat}</td>
              <td><span class={`badge ${r.level === 'MUY ALTO' ? 'b-red' : 'b-amber'}`}>{r.inherent} · {r.level}</span></td>
              <td><span class="badge b-green">{r.residual}</span></td>
              <td style="font-family:var(--font-mono)">{r.eff}%</td>
              <td><span class="mitre-tag">{r.mitre}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

</div>
